      "url": "https://stspg.io/jchxyv3sp1hv",
      "updates": [
        {
          "status": "postmortem",
          "body": "On March 26–27, 2026, customers experienced elevated error rates when using Claude Opus 4.6 and Claude Sonnet 4.6. The issue was caused by a networking performance degradation within our infrastructure that disrupted communication between components of our serving stack. We resolved the incident by migrating the affected workloads to healthy infrastructure, restoring normal service by 9:30 AM PT on March 27.",
          "createdAt": "2026-03-27T17:36:52.273Z"
        },
        {
          "status": "resolved",
          "body": "This incident has been mitigated as of 9:30 PT / 16:30 UTC.",
          "createdAt": "2026-03-27T16:46:24.919Z"
        },
        {
          "status": "monitoring",
          "body": "As of 6:40 PT / 13:40 UTC our error rate has returned to the baseline. We are still monitoring the current situation.",
          "createdAt": "2026-03-27T13:46:20.620Z"
        }
      ]
    },
